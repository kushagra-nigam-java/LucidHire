# .env.example

# Database configuration. 
# In docker-compose, this will point to the postgres container.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lucidhire

# Redis URL for Celery and caching. Used for background logistics tasks.
REDIS_URL=redis://localhost:6379/0

# Groq API Key for LLM orchestration. 
# If left blank, the system falls back to DEMO_MODE with canned responses.
GROQ_API_KEY=

# Google Calendar API credentials (JSON path or string). 
# If blank, defaults to a mock calendar.
GOOGLE_CALENDAR_CREDENTIALS=

# Gmail SMTP configuration for outreach emails. 
# If blank, emails are written to outbox.json.
GMAIL_SMTP_USER=
GMAIL_SMTP_PASSWORD=

# Enable Demo Mode explicitly (forces mock LLM, mock calendar, mock email regardless of other keys)
DEMO_MODE=true
